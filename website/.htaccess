Options -Indexes
DirectoryIndex index.html index.php

<IfModule mod_mime.c>
  AddType video/mp4 .mp4
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # One canonical origin: HTTPS and www.
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} !^www\.posprinteremulator\.com$ [NC]
  # 308 preserves POST requests from installed desktop clients.
  RewriteRule ^ https://www.posprinteremulator.com%{REQUEST_URI} [R=308,L,NE]

  # Public content uses extension-free canonical URLs.
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(?:[\s?]) [NC]
  RewriteRule ^(.+)\.html$ https://www.posprinteremulator.com/$1 [R=301,L,NE]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^([A-Za-z0-9-]+)/?$ $1.html [L]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType video/mp4 "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
</IfModule>

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  <FilesMatch "\.(png|ico|webp|mp4)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
